# Application
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URI=

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRATION=7d

# SMTP (MailDev em Docker para dev, SMTP real em produção)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=admin
SMTP_PASS=admin

# Email de notificação ao criar nova nota
NOTIFICATION_EMAIL=your_email@example.com

# CORS — origem permitida para o frontend (use * para dev local)
CORS_ORIGIN=*
